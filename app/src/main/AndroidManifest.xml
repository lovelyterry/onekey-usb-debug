<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- WRITE_SECURE_SETTINGS is required to toggle global/secure system settings -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.OneKeyUsbDebug">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.OneKeyUsbDebug">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Quick Settings Tile for one-click toggling -->
        <service
            android:name=".ToggleTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_usb"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Broadcast Receiver for external toggle intents -->
        <receiver
            android:name=".ToggleReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.onekey.usbdebug.action.TOGGLE" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
